name: Smartphone_Addiction_MLProject

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      train_path:
        type: str
        default: "smartphone_usage_preprocessing/train.csv"
      test_path:
        type: str
        default: "smartphone_usage_preprocessing/test.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 10
      min_samples_split:
        type: int
        default: 2
      max_features:
        type: str
        default: "sqrt"
      random_state:
        type: int
        default: 42
    command: >
      python modelling.py
        --train_path {train_path}
        --test_path {test_path}
        --n_estimators {n_estimators}
        --max_depth {max_depth}
        --min_samples_split {min_samples_split}
        --max_features {max_features}
        --random_state {random_state}
